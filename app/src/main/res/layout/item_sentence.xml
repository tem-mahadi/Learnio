<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="4dp"
    android:layout_marginVertical="6dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="@color/card_background"
    app:strokeWidth="1dp"
    app:strokeColor="@color/card_stroke">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Header with Topic, Favorite, and Mastery -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp">

            <TextView
                android:id="@+id/text_topic"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Topic"
                android:textSize="11sp"
                android:textColor="@color/text_on_primary"
                android:textStyle="bold"
                android:background="@drawable/bg_topic_badge"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp" />

            <!-- Mastery Stars (Clickable) -->
            <LinearLayout
                android:id="@+id/layoutMastery"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginEnd="8dp"
                android:padding="4dp"
                android:background="@drawable/bg_stars_container">

                <ImageView
                    android:id="@+id/star1"
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:padding="1dp"
                    android:src="@drawable/ic_star_empty"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="@string/rate_mastery" />
                <ImageView
                    android:id="@+id/star2"
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:padding="1dp"
                    android:src="@drawable/ic_star_empty"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="@string/rate_mastery" />
                <ImageView
                    android:id="@+id/star3"
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:padding="1dp"
                    android:src="@drawable/ic_star_empty"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="@string/rate_mastery" />
                <ImageView
                    android:id="@+id/star4"
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:padding="1dp"
                    android:src="@drawable/ic_star_empty"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="@string/rate_mastery" />
                <ImageView
                    android:id="@+id/star5"
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:padding="1dp"
                    android:src="@drawable/ic_star_empty"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="@string/rate_mastery" />
            </LinearLayout>

            <!-- Edit Button (Teacher Mode Only) -->
            <ImageButton
                android:id="@+id/btnEdit"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_marginEnd="4dp"
                android:background="@drawable/bg_favorite_button"
                android:src="@drawable/ic_edit"
                android:scaleType="centerInside"
                android:padding="6dp"
                android:visibility="gone"
                android:contentDescription="@string/edit_sentence" />

            <!-- Favorite Button -->
            <ImageButton
                android:id="@+id/btnFavorite"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="@drawable/bg_favorite_button"
                android:src="@drawable/ic_favorite_outline"
                android:scaleType="centerInside"
                android:padding="6dp"
                android:contentDescription="@string/add_to_favorites" />

        </LinearLayout>

        <!-- Bangla Text (Primary) -->
        <TextView
            android:id="@+id/text_bangla"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="বাংলা বাক্য"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:lineSpacingExtra="2dp"
            android:layout_marginBottom="6dp" />

        <!-- English Text (Secondary) -->
        <TextView
            android:id="@+id/text_english"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="English sentence"
            android:textSize="16sp"
            android:textColor="@color/primary"
            android:textStyle="italic"
            android:lineSpacingExtra="2dp"
            android:layout_marginBottom="12dp" />

        <!-- Practice count indicator -->
        <TextView
            android:id="@+id/tvPracticeCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Practiced 0 times"
            android:textSize="12sp"
            android:textColor="@color/text_tertiary"
            android:layout_marginBottom="12dp"
            android:drawablePadding="4dp"
            android:visibility="gone" />

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/divider"
            android:layout_marginBottom="12dp" />

        <!-- Action Buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_record"
                android:layout_width="0dp"
                android:layout_height="42dp"
                android:layout_weight="1"
                android:layout_marginEnd="4dp"
                android:text="Record"
                android:textSize="11sp"
                android:textAllCaps="false"
                app:backgroundTint="@color/purple_700"
                android:textColor="@color/white"
                app:cornerRadius="8dp"
                app:iconGravity="textStart"
                app:iconPadding="0dp"
                android:paddingHorizontal="4dp"
                style="@style/Widget.Material3.Button" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_play_teacher"
                android:layout_width="0dp"
                android:layout_height="42dp"
                android:layout_weight="1"
                android:layout_marginHorizontal="2dp"
                android:text="Teacher"
                android:textSize="11sp"
                android:textAllCaps="false"
                app:backgroundTint="@color/teal_700"
                android:textColor="@color/white"
                app:cornerRadius="8dp"
                android:paddingHorizontal="4dp"
                style="@style/Widget.Material3.Button" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_play_student"
                android:layout_width="0dp"
                android:layout_height="42dp"
                android:layout_weight="1"
                android:layout_marginStart="4dp"
                android:text="Student"
                android:textSize="11sp"
                android:textAllCaps="false"
                app:backgroundTint="@color/secondary"
                android:textColor="@color/white"
                app:cornerRadius="8dp"
                android:paddingHorizontal="4dp"
                style="@style/Widget.Material3.Button" />

        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
